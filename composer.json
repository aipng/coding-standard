{
	"name": "aipng/coding-standard",
	"type": "phpcodesniffer-standard",
	"description": "AipNg Coding Standard for PHP_CodeSniffer, based on Slevomat and Consistence Coding Standard.",
	"license": "MIT",
	"authors": [
		{
			"name": "Karel Horsky",
			"email": "karel.horsky@centrum.cz"
		}
	],
	"minimum-stability": "stable",
	"require": {
		"PHP": ">=8.4",
		"squizlabs/php_codesniffer": "^4.0.1",
		"slevomat/coding-standard": "^8.26.0"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
